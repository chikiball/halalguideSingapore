# Copy to .env (gitignored) and fill in real values, then `docker compose up -d`.

# ─── DeepSeek (LLM) ──────────────────────────────────────────────
# Required. Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# Optional overrides (defaults shown):
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── Mapbox (map look) ───────────────────────────────────────────
# Public client-side token (pk....). Restrict it to your domain in the
# Mapbox dashboard. If empty, the map falls back to raw OSM tiles.
MAPBOX_TOKEN=pk.your-mapbox-public-token-here
